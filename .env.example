# COFRAP - Configuration locale
# Copie ce fichier en .env et adapte les valeurs a ta machine

# Chemins locaux
BACKEND_PATH=C:\chemin\vers\mspr-2-backend\functions
INFRA_PATH=C:\chemin\vers\mspr-2-infra

# Kubernetes
NAMESPACE_OF=openfaas
NAMESPACE_FN=openfaas-fn
NAMESPACE_DB=data

# Gateway OpenFaaS (port-forward local)
GATEWAY_URL=http://127.0.0.1:8888

# Base de donnees
DB_HOST=postgres.data.svc.cluster.local
DB_NAME=cofrap
DB_USER=cofrap_app
DB_PASSWORD=CHANGE_ME

# SMTP (envoi des QR codes par email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@cofrap.io
